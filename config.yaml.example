# Garlic Example Configuration
# Copy this file to config.yaml and fill in your API keys
#
# Configuration Structure:
# - models: Define LLM endpoints (OpenAI or Bailian)
# - agents: Define agent roles (router, planner, executor, summarizer) that reference models
# - tools: Tool execution settings

models:
  # OpenAI models
  openai-gpt4:
    provider: openai
    model: gpt-4
    api_key: ${OPENAI_API_KEY}
    temperature: 0.7
    max_tokens: 2048

  openai-gpt35:
    provider: openai
    model: gpt-3.5-turbo
    api_key: ${OPENAI_API_KEY}
    temperature: 0.7
    max_tokens: 1024

  # Alibaba Bailian (百炼) models
  bailian-qwen-coder-plus:
    provider: bailian
    model: qwen-coder-plus
    api_key: ${BAILIAN_API_KEY}
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    temperature: 0.7
    max_tokens: 4096
    enable_thinking: true

  bailian-qwen-coder-turbo:
    provider: bailian
    model: qwen-coder-turbo
    api_key: ${BAILIAN_API_KEY}
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    temperature: 0.7
    max_tokens: 4096

  bailian-qwen-max:
    provider: bailian
    model: qwen-max
    api_key: ${BAILIAN_API_KEY}
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    temperature: 0.7
    max_tokens: 4096

agents:
  # Router - analyzes user intent
  router:
    model: qwen3.5-plus-instr

  # Rewriter - rewrites user requests to be self-contained based on conversation history
  rewriter:
    model: qwen3.5-plus

  # Executor - determines which tool to use
  executor:
    model: qwen3.5-plus-instr

  organizer:
    model: qwen3.5-plus

  # Summarizer - summarizes conversation results
  summarizer:
    model: qwen3.5-plus

tools:
  python_path: python
  tools_dir: tools
  skills_dir: skills
  # 工具执行超时时间（秒），默认 300 秒（5 分钟）
  default_timeout: 300

# 禁用的外部 Python 工具名称列表
# 在此列出的工具将不会被加载和执行
disabled_tools:
  # - webrowser  # 示例：禁用 webrowser 工具

# 禁用的 skill 名称列表
# 在此列出的 skill 将不会被加载和显示
disabled_skills:
  # - project_status_report  # 示例：禁用 project_status_report skill

# Tool Generator - Optional configuration for generating new tools
# When enabled, the agent can create new Python tools from descriptions
tool_generator:
  enabled: true
  model: openai-gpt4  # Use a capable model for code generation

conversation_compress:
  disabled: false
  round: 20
  length: 2048

# Memory 系统配置 - 基于 SPLADE 稀疏向量和本地文件存储
memory:
  # 是否启用 memory 系统
  enabled: true
  
  # SPLADE向量模型配置
  splade:
    # 模型名称
    model_name: "naver/splade-v3"
    
    # 模型来源：modelscope 或 huggingface
    source: "modelscope"
    
    # 本地模型缓存路径（相对于项目根目录）
    cache_dir: ".splade_models"
    
    # 是否自动下载模型（如果本地不存在）
    auto_download: true
    
    # 下载超时时间（秒）
    download_timeout: 300
    
    # SPLADE向量维度（稀疏向量的最大词汇表大小）
    vector_dim: 30522
  
  # 向量存储配置
  qdrant:
    # 存储后端：local（本地文件）或 qdrant（Qdrant 服务）
    storage_backend: "local"

    # 本地存储路径（当 storage_backend 为 local 时使用）
    storage_path: ".memory_vectors"

    # Qdrant 连接配置（当 storage_backend 为 qdrant 时使用）
    host: "localhost"
    port: 6334
    # api_key: ""  # Qdrant API 密钥（可选）
    # enable_tls: false  # 是否启用 TLS

    # 集合名称
    collection_name: "garlic_memories"

    # 向量距离度量：Cosine, Euclidean, Dot
    distance: "Cosine"

    # 最大记忆数量
    max_memories: 10000

    # 搜索返回结果数量
    top_k: 5

    # 相似度阈值（0-1），低于此值的结果将被过滤
    similarity_threshold: 0.1
  
  # Memory 存储配置
  storage:
    # 记忆元数据存储目录（JSON 格式）
    metadata_dir: ".memory_metadata"

    # 是否自动从文件系统导入现有记忆
    auto_import: true

  # 记忆清理配置
  # 清理间隔（天数），0 表示不自动清理
  cleanup_interval: 1
  
  # 最大非活跃天数，超过此天数未访问的记忆将被删除
  max_inactive_days: 15
